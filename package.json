		"@types/node": "^24",
		"better-auth": "~1.4.21",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"postgres": "^3.4.8",
		"svelte": "^5.54.0",
		"tailwindcss": "^4.1.18",
		"vite": "^7.3.1"
